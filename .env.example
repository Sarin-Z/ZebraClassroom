# LINE Messaging API credentials
# Get these from https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Teacher LINE User IDs (comma-separated for multiple teachers)
# Find your LINE User ID by messaging the bot and checking the logs
TEACHER_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database file path (relative to project root)
DATABASE_PATH=classroom.db

# App settings
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000
